# ─────────────────────────────────────────────────────────────
# JanVyuha environment — every value below is FREE to obtain.
# Copy this file to `.env` and fill in. The app runs WITHOUT any
# of these (it falls back to an in-browser mock), so you can test
# everything first and add keys as you go.
# ─────────────────────────────────────────────────────────────

# 1) Supabase  →  https://supabase.com  (free tier, no card)
#    Project → Settings → API. Paste the Project URL and the
#    "anon / public" key (safe to expose in the browser).
#    For government comfort, create the project in the India region
#    (South Asia — ap-south-1 / Mumbai).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 2) Google Gemini (Vision AI)  →  https://aistudio.google.com/app/apikey
#    Free API key. This is used ONLY by the serverless function in
#    /api/analyze.ts, so it stays server-side and is never shipped
#    to the browser. Do NOT prefix it with VITE_.
GEMINI_API_KEY=

# Comma-separated origins allowed to call /api/analyze (abuse/cost protection).
# Leave blank in dev/preview. In production set to your deployed URL(s), e.g.
#   https://janvyuha.vercel.app,https://report.telangana.gov.in
ALLOWED_ORIGINS=

# ── White-label branding ────────────────────────────────────
# Which sponsoring authority this build is presented under:
#   neutral   – independent civic-tech pilot (default, safest)
#   telangana | andhra | tamilnadu – state pilot framing
#   national  – national framing (for NITI Aayog review)
VITE_BRAND=

# Default UI language: en | hi | te | ta  (user choice overrides).
# Leave blank to use the brand's default locale.
VITE_DEFAULT_LOCALE=

# Public contact / grievance email shown on the Contact & Privacy pages.
# Set this to a real inbox before any outreach.
VITE_CONTACT_EMAIL=

# ── Notifications (all FREE tiers; optional) ────────────────
# Web Push (VAPID). Generate a free key pair once:
#   npx web-push generate-vapid-keys
# Public key is shipped to the browser (VITE_), private stays server-side.
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email embedded in push payloads (mailto:) — required by web-push.
VAPID_SUBJECT=mailto:admin@example.org

# Service-role key (server-only, NEVER VITE_) — lets /api/notify read push
# subscriptions to send Web Push. Supabase → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email (status updates). Free tier, e.g. Resend or Brevo.
# Server-side only. Leave blank to disable email (in-app + push still work).
EMAIL_API_KEY=
EMAIL_FROM=

# ── Optional ────────────────────────────────────────────────
# Force a backend regardless of the keys above: "mock" | "supabase"
# Leave blank to auto-detect (supabase if the two VITE_ vars exist).
VITE_BACKEND=

# Enable the floating Tester Mode panel in a PRODUCTION build too.
# (It is always on in `npm run dev`.) Set to "true" ONLY for internal
# demos — a real pitch/production build must leave this blank so the
# panel is hard-off. The old ?tester=1 URL escape hatch was removed.
VITE_ENABLE_TESTER=
